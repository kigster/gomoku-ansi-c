# shellcheck disable=SC2148
# vim: ft=bash

PATH_add .
PATH_add bin

command -v brew && {
  PATH_add "$(brew --prefix)/bin"
}

[[ -f .venv/bin/activate ]] && source ".venv/bin/activate"

# ENVIRONMENT drives which .env.{stage}[.local] files Pydantic loads in
# app/config.py. Override per-shell with `ENVIRONMENT=test direnv allow .`
# or by setting it before invoking commands.
export ENVIRONMENT="${ENVIRONMENT:-development}"
