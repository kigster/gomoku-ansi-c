#!/usr/bin/env bash
# Basic setup for C/C++ dev environment
# Run this script to check out the GoogleTest library and build it.

set -e

project_root=$(pwd -P)

os="$(uname -s | tr 'A-Z' 'a-z')"

if [[ $os == darwin ]]; then
  command -v clang >/dev/null || sudo xcode-select --install
  command -v gcc >/dev/null   || brew install gcc
  command -v cmake >/dev/null || brew install cmake
elif [[ $os == linux ]]; then
  command -v gcc || {
    sudo apt-get update -yqq
      sudo apt-get install build-essential -yqq
    }
fi

command -v cmake >/dev/null || {
  echo "Can't seem to find cmake even after an attempted install."
  echo "Please install it and retry."
  exit 1
}

[[ -d ${project_root}/tests/googletest && -f ${project_root}/tests/googletest/CMakeLists.txt ]] || {
  echo 'Something is missing in GoogleTest, updating...'
  rm -rf tests/googletest
  git clone https://github.com/google/googletest.git ${project_root}/tests/googletest
}

cd ${project_root}/tests/googletest
echo "Building GoogleTest..."
mkdir -p build
cd build
echo "Configuring and building GoogleTest..."
set +e

# Unset LDFLAGS to prevent Makefile's LDFLAGS from leaking into CMake
unset LDFLAGS
CC=${CXX}

# On macOS after Xcode/CLT upgrades, Apple Clang may look at an incomplete
# C++ include dir under CLT and miss standard headers (e.g. cstddef). Force
# the SDK's C++ include path so the build finds the full standard library.
cmake_extra=
if [[ $os == darwin ]]; then
  sdk_path=$(xcrun --show-sdk-path 2>/dev/null)
  if [[ -n "$sdk_path" && -d "$sdk_path/usr/include/c++/v1" ]]; then
    cmake_extra="-DCMAKE_OSX_SYSROOT=$sdk_path -DCMAKE_CXX_FLAGS=-I$sdk_path/usr/include/c++/v1"
  fi
fi

cmake .. $cmake_extra && make -j 4 >/dev/null 2>&1
code=$?

if [[ ${code} -ne 0 ]]; then
  make -j 4 >/dev/null 2>&1
  code=$?
fi

cd "${project_root}" >/dev/null || exit 4

declare -a test_libs
test_libs=($(find tests -name 'libgtest*.a'))

if [[ ${#test_libs[@]} -ge 2 ]]; then
  echo -e "\e[1;32mGoogleTest built successfully.\e[0m"
  exit 0
else
  echo -e "\e[1;31mNo test libraries were built. Please check the output above for details.\e[0m"
  exit 1
fi
