#!/usr/bin/env bash
# vim: ft=bash
#
# Deploy-time configuration. Copy to .env (gitignored) and fill in.
# Read ONLY by bin/deploy, which maps these into TF_VAR_* before running
# Terraform. The FastAPI app at runtime does NOT read this file —
# it loads api/.env.{development,test,ci}[.local] instead, driven by the
# ENVIRONMENT variable. Production runtime config arrives via Cloud Run
# env vars set by Terraform.
#
# GCP Setup

# https://ui.honeycomb.io/agentica-group/environments/test/api_keys
HONEYCOMB_INGEST_API_KEY=

# Needed to record deploys in honeycomb as markers
HONEYCOMB_CONFIG_API_KEY=

# Connection Pooled DB (production target — Neon)
# Renamed from DATABASE_URL so `just dotenv-load` can't accidentally export it
# into a runtime FastAPI process (e.g. during local tests) and shadow the
# committed api/.env.{test,development} values.
PRODUCTION_DATABASE_URL="postgresql://USERNAME:PASSWORD@HOSTNAME/gomoku?sslmode=require&channel_binding=require"

# JWT Secret (use 'just jwt-secret' to generate). Same naming rationale as above.
PRODUCTION_JWT_SECRET="..."

# GCP
PROJECT_ID="sand-castle-486503-d0"
REGION="us-central1"
CLUSTER_NAME="gomoku-cluster"

# Custom domain mapped to gomoku-api. Leave empty to skip the domain mapping.
# After first apply, run `terraform output custom_domain_dns_records` (in
# iac/cloud_run/) to get the CNAME to add at your DNS provider.
CUSTOM_DOMAIN="app.gomoku.games"
