#!/usr/bin/env bash
# vim: ft=bash

set +e

declare project_root
project_root="$(cd $(dirname "$(dirname "${BASH_SOURCE[0]}")") && pwd -P)"
export project_root

export BASHMATIC_HOME=${BASHMATIC_HOME:-~/.bashmatic}

# Use Bashmatic to speed up the development process and take advantage of ni  ce UI features.
[[ -d ${BASHMATIC_HOME} ]] || bash -c "$(curl -fsSL https://bashmatic.re1.re); bashmatic-install -q -l" >/dev/null 2>&1
[[ -d ${BASHMATIC_HOME} ]] && source "${BASHMATIC_HOME}/init" >/dev/null 2>&1

GOMOKU_HTTPD_BINARY="bin/gomoku-httpd"
command -v "${GOMOKU_HTTPD_BINARY}" >/dev/null 2>&1 || make build

GOMOKU_HTTPD_BINARY_REGEX="[g]omoku-httpd"

DEFAULT_HOST="0.0.0.0"
DEFAULT_PORT=9500
DEFAULT_FLAGS="-L debug -l log/$(basename ${GOMOKU_HTTPD_BINARY}).log"

flag_verbose=false

declare -i CPU_CORES=0
CPU_CORES=$(getconf _NPROCESSORS_ONLN)
export CPU_CORES

function daemons-count() {
  (daemons-show || echo 0) | wc -l | tr -d ' '
}

# shellcheck disable=SC2120
function daemons-show() {
  if [[ -z "$1" ]]; then
    echo "All ${GOMOKU_HTTPD_BINARY} processes:"
    ps -ef | grep "${GOMOKU_HTTPD_BINARY_REGEX}" | grep -v grep
  else
    ps -ef "$1" r | grep "${GOMOKU_HTTPD_BINARY_REGEX}" | grep -v grep | grep -v "grep" | $1
  fi
}

function usage() {
  echo "USAGE:"
  echo "   gomoku-httpd-ctl start [ -w | --workers <workers> ] "
  echo "                    stop"
  echo "                    show"
  echo "                    htop"
  echo "                    help"
  echo ""
  echo "DESCRIPTION:"
  echo "   Starts ${GOMOKU_HTTPD_BINARY} processes equal to the number of CPU cores."
  echo "   listening on the port starting with the first argument, default is 9900."
}

function parse-argv() {
  [[ -z "$*" ]] && usage && exit 0
  local -i workers="$CPU_CORES"

  while :; do
    case $1 in
    start)
      shift
      [[ $1 =~ ^-w$ ]] && shift
      [[ $1 =~ ^[0-9]+$ ]] && workers="$1" && shift
      daemons-start "$workers"
      ;;
    stop)
      shift
      daemons-stop "$@"
      ;;
    show | status)
      shift
      daemons-status "$1"
      shift
      ;;
    htop)
      shift
      command -v htop >/dev/null 2>&1 ||
        {
          echo "htop is not installed. Please install it first." >&2
          exit 1
        }
      daemons-htop "$@"
      ;;
    -h | --help | help)
      shift
      usage
      exit 0
      ;;
    -v | --verbose)
      flag_verbose=true
      shift
      ;;
    --) # End of all options; anything after will be passed to the action function
      shift
      break
      ;;
    -?*)
      printf 'WARN: Unknown option (ignored): %s\n' "$1" >&2
      exit 127
      shift
      ;;
    *)
      [[ -z "$1" ]] && break
      shift
      ;;
    esac
  done
}

function daemons-htop() {
  htop -F ${GOMOKU_HTTPD_BINARY}
}

function daemons-start() {
  local nproc="${1}"
  local port hapoxy_port
  local i
  local cmd

  ${flag_verbose} && echo -e "${txtylw}Starting ${nproc} ${GOMOKU_HTTPD_BINARY} processes...${clr}"

  [[ -f ${GOMOKU_HTTPD_BINARY} ]] || { make all; }

  mkdir -p log

  info "Starting $(nproc) gomoku-httpd daemons..."

  for ((i = 0; i < nproc; i++)); do
    port=$((DEFAULT_PORT + i))
    haproxy_port=$((DEFAULT_PORT + i + 100))
    cmd="${GOMOKU_HTTPD_BINARY} -b ${DEFAULT_HOST}:${port} -a ${haproxy_port} -d ${DEFAULT_FLAGS}"

    ${flag_verbose} && echo -e -n "${txtgrn}booting: [${cmd}] ... ${clr}"
    run "${cmd}"
    ${flag_verbose} && echo -e "with PID ${txtpur}$!${clr}, exit code $?"
  done

  count_end=$(daemons-count)

  ${flag_verbose} && echo -e "${txtylw}Started $((count_end - count_start)) ${GOMOKU_HTTPD_BINARY} processes.${clr}"
  ${flag_verbose} && echo -e "${txtgrn}Total running ${GOMOKU_HTTPD_BINARY} processes: ${bldylw}${count_end}${clr}."
}

function daemons-stop() {
  local count=$(daemons-count)

  if [[ ${count} -gt 0 ]]; then
    ${flag_verbose} && echo -e "${txtylw}Found ${count} processes running, stopping them...${clr}"
    pkill -9 ${GOMOKU_HTTPD_BINARY}
  else
    ${flag_verbose} && echo -e "${txtgrn}No ${GOMOKU_HTTPD_BINARY} processes found, nothing to stop.${clr}"
  fi

  count=$(daemons-count)
  ${flag_verbose} && echo -e "Currently remaining ${GOMOKU_HTTPD_BINARY} processes: ${bldgrn}${count}${clr}"
}

function daemons-status() {
  daemons-show "$@"
}

function main() {
  parse-argv "$@"
}

main "$@"
