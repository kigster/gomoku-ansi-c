{
  "name": "gomoku-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "gomoku": {
    "backendHost": "127.0.0.1",
    "backendPort": 10000
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "docker-build": "[[ -d frontend ]] && cd frontend; docker build -t gomoku-frontend:latest ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-syntax-highlighter": "16.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "8.18.0",
    "ajv-cli": "0.6.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "4.1.2"
  }
}
